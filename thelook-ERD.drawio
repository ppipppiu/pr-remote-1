        <mxCell id="LE-rtIjZrQeaq1zouxyz-8" parent="1" style="shape=swimlane;rounded=1;whiteSpace=wrap;html=1;startSize=28;fillColor=#EFF6FF;swimlaneFillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#1E3A8A;fontSize=13;align=center;verticalAlign=top;spacingTop=4;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;inventory_items（库存商品实例表）&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;color: rgb(15, 118, 110);&quot;&gt;&lt;b&gt;PK&lt;/b&gt;&lt;/span&gt; id&lt;br&gt;&lt;span style=&quot;color: rgb(37, 99, 235);&quot;&gt;&lt;b&gt;FK&lt;/b&gt;&lt;/span&gt; product_id → products.id&lt;br&gt;&lt;span style=&quot;color: rgb(37, 99, 235);&quot;&gt;&lt;b&gt;FK&lt;/b&gt;&lt;/span&gt; product_distribution_center_id → distribution_centers.id&lt;br&gt;product_name&lt;div&gt;product_brand&lt;br&gt;product_category&lt;/div&gt;&lt;div&gt;product_department&lt;br&gt;cost&lt;/div&gt;&lt;div&gt;product_retail_price&lt;br&gt;created_at&lt;/div&gt;&lt;div&gt;sold_at&lt;/div&gt;" vertex="1">
          <mxGeometry height="275" width="360" x="920" y="470" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-9" parent="1" style="shape=swimlane;rounded=1;whiteSpace=wrap;html=1;startSize=28;fillColor=#FFF7ED;swimlaneFillColor=#FFEDD5;strokeColor=#D97706;fontColor=#78350F;fontSize=13;align=center;verticalAlign=top;spacingTop=4;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;distribution_centers（配送中心表）&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;color: rgb(15, 118, 110);&quot;&gt;&lt;b&gt;PK&lt;/b&gt;&lt;/span&gt; id&lt;br&gt;name&lt;br&gt;latitude&lt;div&gt;longitude&lt;/div&gt;" vertex="1">
          <mxGeometry height="140" width="220" x="1420" y="330" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-10" edge="1" parent="1" source="LE-rtIjZrQeaq1zouxyz-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeWidth=1.5;strokeColor=#0F766E;exitX=0.5;exitY=1;exitPerimeter=1;entryX=0.5;entryY=0;entryPerimeter=1;" target="LE-rtIjZrQeaq1zouxyz-4" value="&lt;span style=&quot;background-color:#FFFFFF&quot;&gt;1 : N&lt;br&gt;&lt;b&gt;users.id = events.user_id&lt;/b&gt;&lt;/span&gt;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-11" edge="1" parent="1" source="LE-rtIjZrQeaq1zouxyz-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeWidth=1.5;strokeColor=#2563EB;exitX=1;exitY=0.4;exitPerimeter=1;entryX=0;entryY=0.4;entryPerimeter=1;" target="LE-rtIjZrQeaq1zouxyz-5" value="&lt;span style=&quot;background-color:#FFFFFF&quot;&gt;1 : N&lt;br&gt;&lt;b&gt;users.id = orders.user_id&lt;/b&gt;&lt;/span&gt;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-12" edge="1" parent="1" source="LE-rtIjZrQeaq1zouxyz-5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeWidth=1.5;strokeColor=#16A34A;exitX=0.5;exitY=1;exitPerimeter=1;entryX=0.5;entryY=0;entryPerimeter=1;" target="LE-rtIjZrQeaq1zouxyz-6" value="&lt;span style=&quot;background-color:#FFFFFF&quot;&gt;1 : N&lt;br&gt;&lt;b&gt;orders.order_id = order_items.order_id&lt;/b&gt;&lt;/span&gt;">
