<mxfile host="app.diagrams.net">
  <diagram name="TheLook ERD" id="Una_mhqTceI0mv_pjpnf">
    <mxGraphModel dx="1510" dy="843" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="LE-rtIjZrQeaq1zouxyz-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;align=left;verticalAlign=middle;fontColor=#111827;fontSize=18;" value="&lt;b style=&quot;font-size:22px&quot;&gt;theLook 电商数据集 ERD（7张表）&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;font-size:12px;color:#4B5563&quot;&gt;基于字段级数据字典 v2：主键/外键关系与核心业务字段&lt;/span&gt;" vertex="1">
          <mxGeometry height="58" width="900" x="60" y="20" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFBEB;strokeColor=#F59E0B;align=left;verticalAlign=top;spacing=10;fontSize=12;fontColor=#374151;" value="&lt;b&gt;图例&lt;/b&gt;&lt;br&gt;&lt;span style=&quot;color:#0F766E&quot;&gt;PK&lt;/span&gt;：主键　 &lt;span style=&quot;color:#2563EB&quot;&gt;FK&lt;/span&gt;：外键&lt;br&gt;实线：核心主外键关系　 虚线：直接但冗余/辅助关联&lt;br&gt;&lt;span style=&quot;color:#B45309&quot;&gt;1 : N&lt;/span&gt;：一对多" vertex="1">
          <mxGeometry height="90" width="360" x="1280" y="20" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-3" parent="1" style="shape=swimlane;rounded=1;whiteSpace=wrap;html=1;startSize=28;fillColor=#EFF6FF;swimlaneFillColor=#DBEAFE;strokeColor=#2563EB;fontColor=#1E3A8A;fontSize=13;align=center;verticalAlign=top;spacingTop=4;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;users（用户基础信息表）&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;color: rgb(15, 118, 110);&quot;&gt;&lt;b&gt;PK&lt;/b&gt;&lt;/span&gt; id&lt;br&gt;first_name&lt;div&gt;last_name&lt;br&gt;email&lt;br&gt;age&lt;/div&gt;&lt;div&gt;gender&lt;br&gt;city&lt;/div&gt;&lt;div&gt;state&amp;nbsp;&lt;/div&gt;&lt;div&gt;country&lt;br&gt;traffic_source&lt;br&gt;created_at&lt;/div&gt;" vertex="1">
          <mxGeometry height="250" width="270" x="60" y="140" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-4" parent="1" style="shape=swimlane;rounded=1;whiteSpace=wrap;html=1;startSize=28;fillColor=#F0FDFA;swimlaneFillColor=#CCFBF1;strokeColor=#0F766E;fontColor=#134E4A;fontSize=13;align=center;verticalAlign=top;spacingTop=4;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;events（用户行为事件表）&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;color: rgb(15, 118, 110);&quot;&gt;&lt;b&gt;PK&lt;/b&gt;&lt;/span&gt; id&lt;br&gt;&lt;span style=&quot;color: rgb(37, 99, 235);&quot;&gt;&lt;b&gt;FK&lt;/b&gt;&lt;/span&gt; user_id → users.id&lt;br&gt;session_id&lt;div&gt;sequence_number&lt;br&gt;event_type&lt;/div&gt;&lt;div&gt;uri&lt;br&gt;traffic_source&lt;br&gt;created_at&lt;/div&gt;" vertex="1">
          <mxGeometry height="215" width="270" x="60" y="520" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-5" parent="1" style="shape=swimlane;rounded=1;whiteSpace=wrap;html=1;startSize=28;fillColor=#F0FDF4;swimlaneFillColor=#DCFCE7;strokeColor=#16A34A;fontColor=#14532D;fontSize=13;align=center;verticalAlign=top;spacingTop=4;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;orders（订单主表）&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;color: rgb(15, 118, 110);&quot;&gt;&lt;b&gt;PK&lt;/b&gt;&lt;/span&gt; order_id&lt;br&gt;&lt;span style=&quot;color: rgb(37, 99, 235);&quot;&gt;&lt;b&gt;FK&lt;/b&gt;&lt;/span&gt; user_id → users.id&lt;br&gt;status&lt;div&gt;gender&lt;br&gt;created_at&lt;br&gt;shipped_at&lt;/div&gt;&lt;div&gt;delivered_at&lt;br&gt;returned_at&lt;br&gt;num_of_item&lt;/div&gt;" vertex="1">
          <mxGeometry height="245" width="275" x="482.5" y="145" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-6" parent="1" style="shape=swimlane;rounded=1;whiteSpace=wrap;html=1;startSize=28;fillColor=#FAF5FF;swimlaneFillColor=#F3E8FF;strokeColor=#9333EA;fontColor=#581C87;fontSize=13;align=center;verticalAlign=top;spacingTop=4;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;order_items（订单商品明细表）&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;color: rgb(15, 118, 110);&quot;&gt;&lt;b&gt;PK&lt;/b&gt;&lt;/span&gt; id&lt;br&gt;&lt;span style=&quot;color: rgb(37, 99, 235);&quot;&gt;&lt;b&gt;FK&lt;/b&gt;&lt;/span&gt; order_id → orders.order_id&lt;br&gt;&lt;span style=&quot;color: rgb(37, 99, 235);&quot;&gt;&lt;b&gt;FK&lt;/b&gt;&lt;/span&gt; user_id → users.id&lt;br&gt;&lt;span style=&quot;color: rgb(37, 99, 235);&quot;&gt;&lt;b&gt;FK&lt;/b&gt;&lt;/span&gt; product_id → products.id&lt;br&gt;&lt;span style=&quot;color: rgb(37, 99, 235);&quot;&gt;&lt;b&gt;FK&lt;/b&gt;&lt;/span&gt; inventory_item_id → inventory_items.id&lt;br&gt;status&lt;div&gt;sale_price&lt;br&gt;created_at&lt;/div&gt;&lt;div&gt;shipped_at&lt;br&gt;delivered_at&lt;/div&gt;&lt;div&gt;returned_at&lt;/div&gt;" vertex="1">
          <mxGeometry height="290" width="320" x="460" y="490" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-7" parent="1" style="shape=swimlane;rounded=1;whiteSpace=wrap;html=1;startSize=28;fillColor=#FEF2F2;swimlaneFillColor=#FEE2E2;strokeColor=#DC2626;fontColor=#7F1D1D;fontSize=13;align=center;verticalAlign=top;spacingTop=4;spacingLeft=10;spacingRight=10;" value="&lt;b&gt;products（商品信息表）&lt;/b&gt;&lt;hr&gt;&lt;span style=&quot;color: rgb(15, 118, 110);&quot;&gt;&lt;b&gt;PK&lt;/b&gt;&lt;/span&gt; id&lt;br&gt;&lt;span style=&quot;color: rgb(37, 99, 235);&quot;&gt;&lt;b&gt;FK&lt;/b&gt;&lt;/span&gt; distribution_center_id → distribution_centers.id&lt;br&gt;name&lt;div&gt;brand&lt;/div&gt;&lt;div&gt;sku&lt;br&gt;category&lt;/div&gt;&lt;div&gt;department&lt;br&gt;cost&lt;/div&gt;&lt;div&gt;retail_price&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="315" x="942.5" y="140" as="geometry" />
