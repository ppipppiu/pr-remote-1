        <mxCell id="LE-rtIjZrQeaq1zouxyz-13" edge="1" parent="1" source="LE-rtIjZrQeaq1zouxyz-7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeWidth=1.5;strokeColor=#DC2626;exitX=0.5;exitY=1;exitPerimeter=1;entryX=0.5;entryY=0;entryPerimeter=1;" target="LE-rtIjZrQeaq1zouxyz-8" value="&lt;span style=&quot;background-color:#FFFFFF&quot;&gt;1 : N&lt;br&gt;&lt;b&gt;products.id = inventory_items.product_id&lt;/b&gt;&lt;/span&gt;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-14" edge="1" parent="1" source="LE-rtIjZrQeaq1zouxyz-7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeWidth=1.5;strokeColor=#DC2626;exitX=0;exitY=0.58;exitPerimeter=1;entryX=1;entryY=0.32;entryPerimeter=1;" target="LE-rtIjZrQeaq1zouxyz-6" value="&lt;span style=&quot;background-color:#FFFFFF&quot;&gt;1 : N&lt;br&gt;&lt;b&gt;products.id = order_items.product_id&lt;/b&gt;&lt;/span&gt;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-15" edge="1" parent="1" source="LE-rtIjZrQeaq1zouxyz-8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeWidth=1.5;strokeColor=#2563EB;exitX=0;exitY=0.55;exitPerimeter=1;entryX=1;entryY=0.7;entryPerimeter=1;" target="LE-rtIjZrQeaq1zouxyz-6" value="&lt;span style=&quot;background-color:#FFFFFF&quot;&gt;1 : N*&lt;br&gt;&lt;b&gt;inventory_items.id = order_items.inventory_item_id&lt;/b&gt;&lt;/span&gt;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-16" edge="1" parent="1" source="LE-rtIjZrQeaq1zouxyz-9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeWidth=1.5;strokeColor=#D97706;exitX=0;exitY=0.35;exitPerimeter=1;entryX=1;entryY=0.45;entryPerimeter=1;" target="LE-rtIjZrQeaq1zouxyz-7" value="&lt;span style=&quot;background-color:#FFFFFF&quot;&gt;1 : N&lt;br&gt;&lt;b&gt;distribution_centers.id = products.distribution_center_id&lt;/b&gt;&lt;/span&gt;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-17" edge="1" parent="1" source="LE-rtIjZrQeaq1zouxyz-9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeWidth=1.5;strokeColor=#D97706;exitX=0;exitY=0.72;exitPerimeter=1;entryX=1;entryY=0.42;entryPerimeter=1;" target="LE-rtIjZrQeaq1zouxyz-8" value="&lt;span style=&quot;background-color:#FFFFFF&quot;&gt;1 : N&lt;br&gt;&lt;b&gt;distribution_centers.id = inventory_items.product_distribution_center_id&lt;/b&gt;&lt;/span&gt;">
          <mxGeometry relative="1" x="0.1478" y="80" as="geometry">
            <mxPoint y="1" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-18" edge="1" parent="1" source="LE-rtIjZrQeaq1zouxyz-3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=none;startArrow=none;strokeWidth=1.5;strokeColor=#6B7280;dashed=1;dashPattern=6 4;exitX=1;exitY=0.78;exitPerimeter=1;entryX=0;entryY=0.7;entryPerimeter=1;" target="LE-rtIjZrQeaq1zouxyz-6" value="&lt;span style=&quot;background-color:#FFFFFF;color:#6B7280&quot;&gt;辅助/冗余关联&lt;br&gt;&lt;b&gt;users.id = order_items.user_id&lt;/b&gt;&lt;/span&gt;">
          <mxGeometry relative="1" x="-0.26" as="geometry">
            <mxPoint y="-1" as="offset" />
          </mxGeometry>
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-19" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#9CA3AF;align=left;verticalAlign=top;spacing=10;fontSize=12;fontColor=#374151;" value="&lt;b&gt;关系说明&lt;/b&gt;&lt;br&gt;• &lt;b&gt;主链路&lt;/b&gt;：用户（users）→ 订单（orders）→ 订单商品明细（order_items）→ 商品/库存（products / inventory_items）。&lt;br&gt;• &lt;b&gt;行为链路&lt;/b&gt;：用户（users）→ 行为事件（events），用于会话、路径与漏斗分析。&lt;br&gt;• &lt;b&gt;履约链路&lt;/b&gt;：商品与库存实例均关联配送中心（distribution_centers）。&lt;br&gt;• &lt;b&gt;虚线&lt;/b&gt;：order_items.user_id 是真实外键，但与 orders.user_id 信息重复；为减少主链路干扰，作为辅助关联展示。&lt;br&gt;• &lt;b&gt;* 注意&lt;/b&gt;：字典已确认 inventory_item_id 可匹配 inventory_items.id，但未核验其在 order_items 中是否唯一；因此结构上先标为 1:N，业务上可能接近 1:0/1。" vertex="1">
          <mxGeometry height="120" width="1170" x="40" y="815" as="geometry" />
        </mxCell>
        <mxCell id="LE-rtIjZrQeaq1zouxyz-20" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EFF6FF;strokeColor=#60A5FA;align=left;verticalAlign=top;spacing=10;fontSize=12;fontColor=#1E3A8A;" value="&lt;b&gt;绘制范围&lt;/b&gt;&lt;br&gt;仅展示主键、外键与关键业务字段；其他完整字段请参见《字段级数据字典 v2》。" vertex="1">
          <mxGeometry height="85" width="320" x="1320" y="850" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
